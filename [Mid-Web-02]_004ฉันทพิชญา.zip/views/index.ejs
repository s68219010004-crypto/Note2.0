<!DOCTYPE html>
<html lang="th" class="transition-colors duration-500">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ถึงฉันในเวอร์ชั่นข้างหน้า 🚀 (ระบบบันทึกลับ)</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = { darkMode: 'class' }
  </script>
  <!-- Font Awesome 6 (Line Icons) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Kanit', sans-serif; }
    summary::-webkit-details-marker { display: none; }
  </style>
</head>
<body class="min-h-screen p-4 sm:p-8 flex flex-col items-center justify-start transition-all duration-500
             bg-[radial-gradient(ellipse_at_top_left,_var(--tw-gradient-stops))] from-pink-200 via-purple-100 to-indigo-200 text-gray-800
             dark:from-slate-950 dark:via-purple-950 dark:to-indigo-950 dark:text-gray-100 relative">

  <!-- 🌟 ปุ่มเปลี่ยนธีมขวาบน (ไล่เฉดสีชวนมอง) -->
  <div class="fixed top-5 right-5 z-40">
    <button id="themeToggleBtn" onclick="toggleTheme()" 
      class="flex items-center gap-2 px-4 py-2.5 rounded-2xl bg-white/80 dark:bg-slate-900/80 backdrop-blur-md shadow-lg border border-white/60 dark:border-purple-500/30 text-xs font-semibold text-purple-700 dark:text-purple-300 hover:scale-105 active:scale-95 transition-all duration-300 hover:shadow-purple-400/30">
      <span id="themeIcon" class="text-sm"><i class="fa-regular fa-sun"></i></span>
      <span id="themeText">โหมดสว่าง</span>
    </button>
  </div>

  <div class="max-w-2xl w-full space-y-8 my-6">

    <!-- 📌 1. ฟอร์มเพิ่มข้อมูล (CREATE - สไตล์การ์ดแก้วไล่สี) -->
    <div class="rounded-3xl shadow-2xl p-6 sm:p-8 border transition-all duration-500
                bg-white/85 border-white/80 shadow-purple-500/10
                dark:bg-slate-900/80 dark:border-purple-500/30 dark:shadow-purple-900/40 backdrop-blur-xl">
      
      <div class="text-center mb-6">
        <!-- ไอคอนการ์ดสีสดใสพร้อมเงาเรืองแสง -->
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl mb-3 shadow-lg shadow-pink-500/30 bg-gradient-to-tr from-purple-600 via-pink-500 to-rose-400 text-white">
          <i class="fa-regular fa-paper-plane text-2xl"></i>
        </div>
        <h1 class="text-2xl sm:text-3xl font-extrabold tracking-wide text-transparent bg-clip-text bg-gradient-to-r from-purple-600 via-pink-600 to-rose-500 dark:from-purple-300 dark:via-pink-200 dark:to-rose-300">
          ถึงฉันในเวอร์ชั่นข้างหน้า
        </h1>
        <p class="text-xs sm:text-sm mt-1 text-purple-600/80 dark:text-purple-300/80 font-medium">
          ✨ เขียนข้อความ ความฝัน และกำลังใจฝากข้ามเวลา
        </p>
      </div>

      <form action="/add" method="POST" class="space-y-5">
        <div>
          <label class="block text-xs font-semibold mb-1.5 text-gray-700 dark:text-purple-200 flex items-center gap-1.5">
            <i class="fa-regular fa-bookmark text-pink-500"></i> เรื่องที่อยากบอกตัวเอง
          </label>
          <input type="text" name="title" placeholder="เช่น ถึงฉันในวันที่ทำตามฝันสำเร็จ..." required
            class="w-full px-4 py-3 rounded-2xl border focus:outline-none focus:ring-2 transition-all duration-300 text-sm
                   bg-white/70 border-purple-200/80 focus:ring-pink-400 focus:border-transparent text-gray-800 placeholder-gray-400
                   dark:bg-slate-950/60 dark:border-purple-500/30 dark:focus:ring-purple-400 dark:text-gray-100">
        </div>

        <div>
          <label class="block text-xs font-semibold mb-1.5 text-gray-700 dark:text-purple-200 flex items-center gap-1.5">
            <i class="fa-regular fa-comment-dots text-purple-500"></i> ข้อความถึงอนาคต
          </label>
          <textarea name="detail" rows="3" placeholder="เขียนรายละเอียดความทรงจำตรงนี้..." required
            class="w-full px-4 py-3 rounded-2xl border focus:outline-none focus:ring-2 transition-all duration-300 text-sm resize-none
                   bg-white/70 border-purple-200/80 focus:ring-pink-400 focus:border-transparent text-gray-800 placeholder-gray-400
                   dark:bg-slate-950/60 dark:border-purple-500/30 dark:focus:ring-purple-400 dark:text-gray-100"></textarea>
        </div>

        <button type="submit" 
          class="w-full py-3.5 px-6 rounded-2xl font-semibold text-white shadow-lg shadow-pink-500/25 hover:shadow-pink-500/40 transition-all duration-300 transform hover:-translate-y-0.5 active:scale-95 flex items-center justify-center gap-2 text-sm
                 bg-gradient-to-r from-purple-600 via-pink-500 to-rose-500 hover:from-purple-700 hover:to-rose-600">
          <i class="fa-solid fa-plus text-xs"></i> บันทึกข้อความข้ามเวลา (Create)
        </button>
      </form>
    </div>

    <!-- 📖 2. รายการแสดงข้อมูลสดใส (READ + Hidden Details) -->
    <div class="space-y-4">
      <h2 class="text-base font-bold flex items-center gap-2 text-purple-900 dark:text-purple-200">
        <i class="fa-regular fa-folder-open text-pink-500"></i> กล่องข้อความความทรงจำ (คลิกเพื่ออ่าน)
      </h2>

      <% if (typeof notes !== 'undefined' && notes.length > 0) { %>
        <div class="grid gap-3">
          <% notes.forEach(note => { %>
            <details class="group rounded-2xl border shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden
                            bg-white/90 border-white/80 dark:bg-slate-900/80 dark:border-purple-500/30 backdrop-blur-md">
              
              <!-- แถบหัวข้อไล่สีเบาๆ -->
              <summary class="p-4.5 cursor-pointer flex justify-between items-center select-none list-none group-open:border-b group-open:border-purple-100 dark:group-open:border-purple-500/20 group-open:bg-purple-50/40 dark:group-open:bg-purple-900/20 transition-all">
                <div class="flex items-center gap-3">
                  <span class="w-8 h-8 rounded-xl flex items-center justify-center bg-gradient-to-tr from-purple-500 to-pink-500 text-white text-xs shadow-sm">
                    <i class="fa-regular fa-envelope group-open:hidden"></i>
                    <i class="fa-regular fa-envelope-open hidden group-open:inline"></i>
                  </span>
                  <h3 class="font-semibold text-sm text-gray-800 dark:text-purple-100">
                    <%= note.title %>
                  </h3>
                </div>
                
                <div class="flex items-center gap-3">
                  <span class="text-xs font-medium text-pink-600 dark:text-pink-400 flex items-center gap-1 bg-pink-50 dark:bg-pink-500/10 px-2.5 py-1 rounded-full border border-pink-200/60 dark:border-pink-500/20">
                    <span class="group-open:hidden flex items-center gap-1"><i class="fa-regular fa-eye"></i> เปิดอ่าน</span>
                    <span class="hidden group-open:flex items-center gap-1"><i class="fa-regular fa-eye-slash"></i> ซ่อน</span>
                  </span>
                  <i class="fa-solid fa-chevron-down text-xs text-purple-400 transition-transform duration-300 group-open:rotate-180"></i>
                </div>
              </summary>

              <!-- รายละเอียดข้อความ -->
              <div class="p-5 bg-gradient-to-b from-purple-50/30 to-pink-50/20 dark:from-slate-950/40 dark:to-purple-950/20 space-y-4">
                <div class="text-sm text-gray-700 dark:text-purple-200/90 whitespace-pre-line leading-relaxed pl-3 border-l-3 border-pink-400 dark:border-purple-400">
                  <%= note.detail %>
                </div>

                <!-- ปุ่มแก้ไข และ ลบ (สีสันสดใส) -->
                <div class="flex items-center justify-end gap-2 pt-2 border-t border-purple-100/60 dark:border-purple-500/10">
                  <button onclick="openEditModal('<%= note.id %>', '<%= note.title %>', '<%= note.detail %>')" 
                    class="px-3.5 py-1.5 rounded-xl text-xs font-semibold bg-amber-100 text-amber-800 hover:bg-amber-200 border border-amber-300/60 dark:bg-amber-500/20 dark:text-amber-300 dark:border-amber-500/30 transition shadow-sm flex items-center gap-1.5">
                    <i class="fa-regular fa-pen-to-square"></i> แก้ไข
                  </button>

                  <form action="/delete/<%= note.id %>" method="POST" onsubmit="return confirm('ยืนยันที่จะลบบันทึกนี้ไหมครับ?');">
                    <button type="submit" 
                      class="px-3.5 py-1.5 rounded-xl text-xs font-semibold bg-rose-100 text-rose-800 hover:bg-rose-200 border border-rose-300/60 dark:bg-rose-500/20 dark:text-rose-300 dark:border-rose-500/30 transition shadow-sm flex items-center gap-1.5">
                      <i class="fa-regular fa-trash-can"></i> ลบ
                    </button>
                  </form>
                </div>
              </div>

            </details>
          <% }); %>
        </div>
      <% } else { %>
        <div class="text-center p-8 rounded-3xl border border-dashed bg-white/60 dark:bg-slate-900/40 border-purple-300 dark:border-purple-500/30 text-purple-600 dark:text-purple-300/60 text-sm flex flex-col items-center gap-2 backdrop-blur-sm">
          <i class="fa-regular fa-folder-closed text-3xl text-pink-400"></i>
          <span>ยังไม่มีข้อความถูกบันทึกไว้ ลองเขียนบันทึกแรกดูสิครับ! ✨</span>
        </div>
      <% } %>
    </div>

  </div>

  <!-- ✏️ 3. หน้าต่างเด้งแก้ไขข้อมูล (UPDATE MODAL สไตล์กล่องแก้ว) -->
  <div id="editModal" class="fixed inset-0 bg-slate-950/60 backdrop-blur-md z-50 hidden flex items-center justify-center p-4">
    <div class="max-w-md w-full bg-white dark:bg-slate-900 rounded-3xl p-6 shadow-2xl border border-purple-100 dark:border-purple-500/30 space-y-4">
      <div class="flex justify-between items-center pb-3 border-b border-purple-100 dark:border-purple-500/20">
        <h3 class="font-bold text-base text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600 dark:from-purple-300 dark:to-pink-300 flex items-center gap-2">
          <i class="fa-regular fa-pen-to-square text-pink-500"></i> แก้ไขข้อความ (Update)
        </h3>
        <button onclick="closeEditModal()" class="text-gray-400 hover:text-pink-500 dark:hover:text-white text-lg transition">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <form action="/update" method="POST" class="space-y-4">
        <input type="hidden" id="editId" name="id">
        <div>
          <label class="block text-xs font-semibold mb-1 text-gray-700 dark:text-purple-200">หัวข้อเรื่อง</label>
          <input type="text" id="editTitle" name="title" required
            class="w-full px-4 py-2.5 rounded-xl border text-sm bg-purple-50/40 border-purple-200 focus:outline-none focus:ring-2 focus:ring-pink-400 dark:bg-slate-950 dark:border-purple-500/30 text-gray-800 dark:text-gray-100">
        </div>
        <div>
          <label class="block text-xs font-semibold mb-1 text-gray-700 dark:text-purple-200">รายละเอียด</label>
          <textarea id="editDetail" name="detail" rows="3" required
            class="w-full px-4 py-2.5 rounded-xl border text-sm resize-none bg-purple-50/40 border-purple-200 focus:outline-none focus:ring-2 focus:ring-pink-400 dark:bg-slate-950 dark:border-purple-500/30 text-gray-800 dark:text-gray-100"></textarea>
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" onclick="closeEditModal()" class="px-4 py-2 rounded-xl text-xs font-medium bg-gray-100 text-gray-600 dark:bg-slate-800 dark:text-gray-300">ยกเลิก</button>
          <button type="submit" class="px-4 py-2 rounded-xl text-xs font-semibold text-white bg-gradient-to-r from-purple-600 to-pink-500 hover:from-purple-700 hover:to-pink-600 shadow-md shadow-pink-500/20">บันทึกการแก้ไข</button>
        </div>
      </form>
    </div>
  </div>

  <!-- ⚙️ JavaScript ควบคุม Modal และ ธีม -->
  <script>
    function initTheme() {
      const savedTheme = localStorage.getItem('user-theme');
      if (savedTheme) {
        setTheme(savedTheme);
      } else {
        const hour = new Date().getHours();
        setTheme((hour >= 6 && hour < 18) ? 'light' : 'dark');
      }
    }
    function setTheme(theme) {
      const html = document.documentElement;
      const icon = document.getElementById('themeIcon');
      const text = document.getElementById('themeText');

      if (theme === 'dark') {
        html.classList.add('dark');
        icon.innerHTML = '<i class="fa-regular fa-moon text-purple-300"></i>';
        text.textContent = 'โหมดมืด';
      } else {
        html.classList.remove('dark');
        icon.innerHTML = '<i class="fa-regular fa-sun text-amber-500"></i>';
        text.textContent = 'โหมดสว่าง';
      }
      localStorage.setItem('user-theme', theme);
    }
    function toggleTheme() {
      const isDark = document.documentElement.classList.contains('dark');
      setTheme(isDark ? 'light' : 'dark');
    }
    initTheme();

    function openEditModal(id, title, detail) {
      document.getElementById('editId').value = id;
      document.getElementById('editTitle').value = title;
      document.getElementById('editDetail').value = detail;
      document.getElementById('editModal').classList.remove('hidden');
    }
    function closeEditModal() {
      document.getElementById('editModal').classList.add('hidden');
    }
  </script>
</body>
</html>